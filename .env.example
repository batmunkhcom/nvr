# ============================================================================
# NVR System — Environment Variables
# ============================================================================
# ХУУЛБАР: Жинхэнэ утгуудыг .env файлд бичих бөгөөд .env-г ХЭЗЭЭЧ commit хийж болохгүй!
# Энэ файл нь ямар хувьсагч шаардлагатайг харуулах загвар юм.
# ============================================================================

# --- Database (PostgreSQL + TimescaleDB) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=nvr
POSTGRES_USER=nvr_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# --- JWT Security ---
JWT_SECRET_KEY=change_me_to_random_64_char_string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
API_LOG_LEVEL=info
API_CORS_ORIGINS=*

# --- Stream Manager ---
STREAM_MANAGER_HOST=stream-manager
STREAM_MANAGER_PORT=8001
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# --- Discovery ---
DISCOVERY_SUBNETS=192.168.1.0/24,192.168.2.0/24
DISCOVERY_ONVIF_TIMEOUT=30
DISCOVERY_SCAN_TIMEOUT=10
VENDOR_PATTERNS_PATH=/app/config/vendor_patterns.yml

# --- Storage ---
# Local recording path (mounted inside container)
STORAGE_LOCAL_PATH=/data/recordings
# S3/MinIO
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_change_me
S3_BUCKET=nvr-recordings
S3_SECURE=false

# --- AI Engine ---
AI_MODEL_PATH=/app/models
AI_YOLO_MODEL=yolov8n.onnx
AI_CONFIDENCE_THRESHOLD=0.5
AI_DEVICE=cpu
# AI_DEVICE=cuda  # GPU дэмждэг бол

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_BROWSER=true

# --- Nginx ---
NGINX_HOST=localhost
NGINX_PORT=80
NGINX_SSL_PORT=443

# --- Docker ---
COMPOSE_PROJECT_NAME=nvr
DOCKER_REGISTRY=
IMAGE_TAG=latest

# --- Monitoring (optional, Phase 5) ---
# PROMETHEUS_ENABLED=true
# GRAFANA_ADMIN_PASSWORD=admin
